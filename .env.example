# GreenMLOps Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================
# Electricity Maps API
# ============================================================
# Get your API key from: https://www.electricitymaps.com/
# Free tier provides current carbon intensity only
# Paid tier includes forecast endpoint
ELECTRICITY_MAPS_API_KEY=your_api_key_here
ELECTRICITY_MAPS_ZONE=US-CAL-CISO

# ============================================================
# MLflow Tracking (DagsHub)
# ============================================================
MLFLOW_TRACKING_URI=https://dagshub.com/pramodkumar26/greenmlops.mlflow
MLFLOW_TRACKING_USERNAME=pramodkumar26
MLFLOW_TRACKING_PASSWORD=your_dagshub_token_here

# ============================================================
# GCP Configuration (for deployment phase)
# ============================================================
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1
GCS_BUCKET=greenmlops-dvc

# ============================================================
# Paths (local development)
# ============================================================
CAISO_CSV_PATH=data/raw/carbon/caiso_2024_hourly.csv
COOLDOWN_STATE_DIR=airflow/include/cooldown
